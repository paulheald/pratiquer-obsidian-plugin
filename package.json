{
	"name": "pratiquer-obsidian-plugin",
	"version": "0.3.0",
	"description": "Send vocab lists straight from Obsidian into Pratiquer flashcard sets.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
