	},
	"keywords": [],
	"author": "Paul Heald",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.5",
		"builtin-modules": "3.3.0",
		"esbuild": "0.19.11",
		"obsidian": "latest",
		"tslib": "2.6.2",
		"typescript": "5.3.3"
	}
}
